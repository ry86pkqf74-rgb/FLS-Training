# FLS-Training Environment Configuration
# Copy to .env and fill in values

# === API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# === Paths ===
VIDEO_STORAGE_PATH=./videos
MEMORY_PATH=./memory
DUCKDB_PATH=./data/fls_training.duckdb

# === Model Defaults ===
TEACHER_A_MODEL=claude-sonnet-4-20250514
TEACHER_B_MODEL=gpt-4o
CRITIQUE_MODEL=claude-sonnet-4-20250514
COACH_MODEL=claude-sonnet-4-20250514     # dedicated coach agent (separate from scoring)
STUDENT_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# === Frame Extraction ===
DEFAULT_N_FRAMES=20
DEFAULT_FINAL_STATE_FRAMES=3
MAX_FRAME_DIMENSION=1280
FRAME_STRATEGY=motion              # "uniform" (fast) or "motion" (optical-flow keyframes)

# === RunPod (for training) ===
RUNPOD_API_KEY=
RUNPOD_DEFAULT_GPU=NVIDIA RTX 4090  # downgraded from A100 — QLoRA fits in 24GB

# === Multi-Turn Critique ===
REVIEW_ITERATIONS=2           # max critique rounds (early-stop if agreement > 0.92)
CRITIQUE_TEMPERATURE=0.3      # low temp for deterministic critique
SCORING_TEMPERATURE=0.0       # zero temp for reproducible scoring
CONSENSUS_EARLY_STOP=0.92     # skip round 2 if agreement exceeds this

# === Training Framework ===
TRAINING_FRAMEWORK=unsloth    # unsloth (preferred) or hf_trainer
