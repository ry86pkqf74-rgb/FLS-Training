# === API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# === Optional: Weights & Biases ===
WANDB_API_KEY=
WANDB_PROJECT=fls-training

# === Optional: Hugging Face (for model upload) ===
HF_TOKEN=

# === RunPod (only needed on RunPod pod) ===
RUNPOD_API_KEY=

# === Backblaze B2 (artifact storage for cross-pod sync) ===
# Use a SCOPED key (bucket=fls-checkpoints, capabilities list/read/write/delete
# files only). NEVER put the master key on a rented pod.
# Create via: b2 key create --bucket fls-checkpoints fls-training-pods \
#               listBuckets,listFiles,readFiles,writeFiles,deleteFiles
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=fls-checkpoints

# === Paths ===
FLS_VIDEO_DIR=~/videos
FLS_DB_PATH=./memory/fls_training.duckdb
