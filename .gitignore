.env
.DS_Store
.venv/
__pycache__/
*.pyc
*.egg-info/
fls_training.egg-info/
dist/
build/

# ── Intentionally tracked data files (DO NOT add to .gitignore) ──
# These are append-only data files consumed by the harvest / scoring
# pipeline and must stay in version control:
#   harvest_log.jsonl             — used by 011_harvest_youtube.py,
#                                   011c_harvest_from_csv.py,
#                                   021_batch_score.py, 030_run_consensus.py
#   playlist_classification.jsonl — used by 012_harvest_playlist.py
#   memory/learning_ledger.jsonl  — LearningLog append-only event log
#   memory/scores/**/*.json       — per-video score JSONs backing DuckDB
# If a future cleanup pass wants to move these, update every consumer
# first; do not just gitignore them.

*.duckdb
*.duckdb.wal
*.mov
*.mp4
*.avi
wandb/
outputs/
.ipynb_checkpoints/
*.log
memory/frames/
.tmp_*

# ── Large artifacts: NEVER push to GitHub ──
# Checkpoints (use Contabo S8 or object storage)
memory/model_checkpoints/*/checkpoint-*/
memory/model_checkpoints/*/*.safetensors
memory/model_checkpoints/*/*.bin
*.safetensors
*.bin
*.gguf

# Extracted frames (regenerate from video)
data/frames/
frames/

# Large training data exports (the JSONL manifests are fine; raw frames are not)
training/data/*/frames/
training/data/*/images/

# LASANA bulk data (annotations CSVs and metadata are committed; everything else is local-only)
data/external/lasana/videos/
data/external/lasana/samples/example_videos.zip
data/external/lasana/samples/example_videos/
data/external/lasana/annotations/Annotation.zip
*.mkv

# PETRAW bulk data (Synapse, non-commercial). READMEs + scripts committed; videos local-only.
data/external/petraw/videos/
data/external/petraw/segmentation/
data/external/petraw/kinematics/
data/external/petraw/_meta/
data/external/petraw/*.zip
data/external/petraw/download.log

# JIGSAWS bulk data (academic only). Videos + kinematics .txt files
# stay out; meta_file_*.txt, readme.txt, and gesture transcriptions
# (small text files needed for training) are tracked.
data/external/jigsaws/**/video/
data/external/jigsaws/**/kinematics/
data/external/jigsaws/Experimental_setup/
data/external/jigsaws/**/*.avi
data/external/jigsaws/**/*.mp4
data/external/jigsaws/*.zip
data/external/jigsaws/download.log
data/external/jigsaws/move.log
data/external/jigsaws/.DS_Store
data/external/jigsaws/**/.DS_Store

# SimSurgSkill bulk data (non-commercial GCS). Videos + zip local-only.
data/external/simsurgskill/simsurgskill_2021_dataset/
data/external/simsurgskill/*.zip
data/external/simsurgskill/download.log
harvested_videos/

# Keep v17_v003 adapter weights tracked via Git LFS (override the bulk safetensors block above).
!memory/model_checkpoints/v17_v003/adapter_model.safetensors
!memory/model_checkpoints/v17_v003/training_args.bin
