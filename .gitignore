# LASANA bulk data (annotations CSVs and metadata are committed; everything else is local-only)
data/external/lasana/videos/
data/external/lasana/samples/example_videos.zip
data/external/lasana/samples/example_videos/
data/external/lasana/annotations/Annotation.zip
*.mkv

# PETRAW bulk data (Synapse, non-commercial). READMEs + scripts committed; videos local-only.
data/external/petraw/videos/
data/external/petraw/segmentation/
data/external/petraw/kinematics/
data/external/petraw/_meta/
data/external/petraw/*.zip
data/external/petraw/download.log

# JIGSAWS bulk data (academic only). Videos + kinematics .txt files
# stay out; meta_file_*.txt, readme.txt, and gesture transcriptions
# (small text files needed for training) are tracked.
data/external/jigsaws/**/video/
data/external/jigsaws/**/kinematics/
data/external/jigsaws/**/*.avi
data/external/jigsaws/**/*.mp4
data/external/jigsaws/*.zip
data/external/jigsaws/download.log
data/external/jigsaws/move.log
data/external/jigsaws/.DS_Store
data/external/jigsaws/**/.DS_Store

# SimSurgSkill bulk data (non-commercial GCS). Videos + zip local-only.
data/external/simsurgskill/simsurgskill_2021_dataset/
data/external/simsurgskill/*.zip
data/external/simsurgskill/download.log
